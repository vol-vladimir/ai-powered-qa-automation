{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "cypress/**/*.ts",
    "cypress.config.ts",
    "playwright.config.ts",
    "tests/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts",
    "fixtures/**/*.ts"
  ]
}
